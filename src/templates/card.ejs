<svg
  xmlns="http://www.w3.org/2000/svg"
  width="495"
  height="195"
  viewBox="0 0 495 195"
  role="img"
  aria-label="GitHub profile stats for <%= stats.name %>"
>
  <style>
    .bg { fill: <%= theme.background %>; }
    .border { fill: none; stroke: <%= theme.border %>; stroke-width: 1; }
    .title { fill: <%= theme.accent %>; font: 600 18px 'Segoe UI', Ubuntu, Sans-Serif; }
    .stat { fill: <%= theme.text %>; font: 600 14px 'Segoe UI', Ubuntu, Sans-Serif; }
    .muted { fill: <%= theme.mutedText || theme.text %>; font: 400 12px 'Segoe UI', Ubuntu, Sans-Serif; opacity: 0.9; }
    .icon { fill: <%= theme.accent %>; }
    .stagger { opacity: 0; animation: fadeIn .35s ease forwards; }
    .s1 { animation-delay: 150ms; } .s2 { animation-delay: 300ms; } .s3 { animation-delay: 450ms; }
    .s4 { animation-delay: 600ms; } .s5 { animation-delay: 750ms; }
    @keyframes fadeIn { to { opacity: 1; } }
  </style>

  <rect x="0.5" y="0.5" width="494" height="194" rx="4.5" class="bg"/>
  <rect x="0.5" y="0.5" width="494" height="194" rx="4.5" class="border"/>

  <text x="25" y="35" class="title"><%= stats.name %>'s GitHub Stats</text>

  <% const rows = [
    ['★', 'Total Stars Earned', stats.total_stars],
    ['⑂', 'Total Forks', stats.total_forks],
    ['⌘', 'Total Public Repos', stats.public_repos],
    ['◉', 'Followers', stats.followers],
    ['↗', 'Following', stats.following],
  ]; %>
  <% rows.forEach((row, index) => { %>
    <g class="stagger s<%= index + 1 %>" transform="translate(25, <%= 65 + index * 23 %>)">
      <text class="icon" x="0" y="0" font-size="15"><%= row[0] %></text>
      <text class="stat" x="25" y="0"><%= row[1] %>:</text>
      <text class="stat" x="210" y="0"><%= row[2] %></text>
    </g>
  <% }) %>

  <% const bio = (stats.bio || `@${stats.login}`).replace(/\s+/g,' ').trim(); %>
  <text x="25" y="178" class="muted">
    <%= bio.length > 74 ? bio.slice(0, 74) + "..." : bio %>
  </text>
</svg>
