<svg
  xmlns="http://www.w3.org/2000/svg"
  width="420"
  height="170"
  viewBox="0 0 420 170"
  role="img"
  aria-label="GitHub profile stats for <%= stats.name %>"
>
  <style>
    .bg { fill: <%= theme.background %>; }
    .border { fill: none; stroke: <%= theme.border %>; stroke-width: 2; }
    .title { fill: <%= theme.text %>; font: 700 16px 'Segoe UI', Ubuntu, Sans-Serif; }
    .label { fill: <%= theme.mutedText || theme.text %>; font: 600 12px 'Segoe UI', Ubuntu, Sans-Serif; }
    .value { fill: <%= theme.accent %>; font: 700 14px 'Segoe UI', Ubuntu, Sans-Serif; }
    .bio { fill: <%= theme.text %>; font: 400 11px 'Segoe UI', Ubuntu, Sans-Serif; opacity: 0.9; }
  </style>

  <rect x="0" y="0" width="420" height="170" rx="12" class="bg"/>
  <rect x="1" y="1" width="418" height="168" rx="11" class="border"/>

  <!-- Avatar -->
  <defs>
    <clipPath id="avatarClip">
      <circle cx="55" cy="55" r="28"/>
    </clipPath>
  </defs>

  <image
    href="<%= stats.avatar_url %>"
    x="27"
    y="27"
    width="56"
    height="56"
    clip-path="url(#avatarClip)"
    preserveAspectRatio="xMidYMid slice"
  />

  <!-- Title -->
  <text x="98" y="45" class="title"><%= stats.name %></text>

  <!-- Bio (trim to keep SVG neat) -->
  <% const bio = (stats.bio || '').replace(/\s+/g,' ').trim(); %>
  <text x="98" y="66" class="bio">
    <%= bio.length > 46 ? bio.slice(0, 46) + "..." : bio %>
  </text>

  <!-- Stats -->
  <text x="30" y="115" class="label">Repos</text>
  <text x="30" y="136" class="value"><%= stats.public_repos %></text>

  <text x="150" y="115" class="label">Followers</text>
  <text x="150" y="136" class="value"><%= stats.followers %></text>

  <text x="290" y="115" class="label">Following</text>
  <text x="290" y="136" class="value"><%= stats.following %></text>
</svg>